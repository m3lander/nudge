# Photon Spectrum cloud credentials (photon.codes dashboard → project settings).
# The agent texts from your Photon-managed iMessage number.
SPECTRUM_PROJECT_ID=your-project-id
SPECTRUM_PROJECT_SECRET=your-project-secret

# Who is allowed to talk to the agent (comma-separated phones/emails).
OWNER_HANDLE=+15551234567

# Agent model as provider/model (must be authed in ~/.pi/agent — run `pi` once to log in).
AGENT_MODEL=openai-codex/gpt-5.6-terra

# Demo mode: divide all check-in delays by this ("10 minutes" fires in 30s at 20).
TIME_SCALE=1

# 1 = don't invoke the agent, just reply "echo: <text>" (plumbing test).
ECHO_MODE=0

AGENT_NAME=Momo

# Optional: control-plane port (default 4550), no-reply watchdog minutes (default 5),
# distraction sites for the sidecar.
# CONTROL_PORT=4550
# WATCHDOG_MINUTES=5
# DISTRACTION_SITES=x.com,twitter.com,instagram.com,tiktok.com,reddit.com,facebook.com,youtube.com
